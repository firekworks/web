# Supabase client, public in browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Google Maps client/server.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=

# Google Calendar, optional for external sync.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=

# Meta, optional future provider.
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# WhatsApp Business, optional future provider.
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Firekworks internal linking.
NEXT_PUBLIC_APP_URL=
FIREKWORKS_STATS_URL=
FIREKWORKS_STATS_API_KEY=
